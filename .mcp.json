{
  "mcpServers": {
    "atlassian": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"],
      "env": {
        "MCP_REMOTE_STATE_DIR": "~/.config/mcp-remote/atlassian"
      }
    },
    "snowflake": {
      "command": ".venv/bin/mcp-server-snowflake",
      "args": [
        "--service-config-file", "./config/snowflake.yaml",
        "--authenticator", "externalbrowser",
        "--transport", "stdio"
      ],
      "env": {
        "SNOWFLAKE_ACCOUNT": "${SNOWFLAKE_ACCOUNT}",
        "SNOWFLAKE_USER": "${SNOWFLAKE_USER}",
        "SNOWFLAKE_DATABASE": "${SNOWFLAKE_DATABASE}",
        "SNOWFLAKE_WAREHOUSE": "${SNOWFLAKE_WAREHOUSE}"
      }
    },
    "datadog": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    },
    "google": {
      "type": "http",
      "url": "https://google-workspace-mcp-server-834963730936.us-central1.run.app/mcp"
    }

  }
}
